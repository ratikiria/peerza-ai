# ────────────────────────────────────────────────────────────────────────────
# Peerza.ai — environment template
# Copy to `.env.local` for dev, set in Railway dashboard for production.
# Never commit `.env` files. Anything starting with NEXT_PUBLIC_ is shipped
# to the browser bundle — keep secrets out of those.
# ────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────

# Public origin of the deployed app. Used by NextAuth callbacks, Stripe
# redirects, email templates, and the proxy CSRF check.
NEXTAUTH_URL=https://peerza.ai

# 32+ random bytes. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Postgres connection string. Railway exposes this as DATABASE_URL on the
# Postgres plugin — link it via the Railway dashboard, no manual paste needed.
# Format: postgresql://user:pass@host:5432/dbname?schema=public
DATABASE_URL=

# Comma-separated extra origins allowed to make mutating /api/* requests.
# Production peerza.ai is auto-allowed via the Host header. Use this for
# preview deploys, staging subdomain, or a separate admin tool.
# Example: ALLOWED_ORIGINS=https://staging.peerza.ai,https://admin.peerza.ai
ALLOWED_ORIGINS=

# ── Auth providers ──────────────────────────────────────────────────────────

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://peerza.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────

# Sign up at https://resend.com — free tier: 100 emails/day, 3000/month.
# Add peerza.ai as a sending domain and set the SPF + DKIM DNS records
# Resend gives you. Then create an API key with "Sending access" only.
RESEND_API_KEY=

# Verified sender — must be a domain you've configured in Resend.
EMAIL_FROM="Peerza <hello@peerza.ai>"
EMAIL_REPLY_TO=hello@peerza.ai

# ── Payments ────────────────────────────────────────────────────────────────

# Stripe — test keys for dev (sk_test_...), live keys for prod (sk_live_...).
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Webhook signing secret. Create one webhook endpoint per environment at
# https://dashboard.stripe.com/webhooks pointing at /api/webhooks/stripe.
# Listen for: checkout.session.completed, customer.subscription.{updated,deleted}
STRIPE_WEBHOOK_SECRET=

# Coinbase Commerce — optional crypto checkout. Leave blank to disable.
# https://commerce.coinbase.com/dashboard/settings
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# ── AI ──────────────────────────────────────────────────────────────────────

# Anthropic — for AI Tutor and translation scripts.
# https://console.anthropic.com — top up credits or set a monthly cap.
ANTHROPIC_API_KEY=

# ElevenLabs — voice for AI Tutor. Optional; voice falls back if blank.
# https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Market data ─────────────────────────────────────────────────────────────

# FMP — earnings calendar + financials. Free tier: 250 calls/day.
# https://financialmodelingprep.com
FINANCIAL_MODELING_PREP_API_KEY=

# ── Web3 (Solana) ───────────────────────────────────────────────────────────

# Helius RPC — devnet during pre-launch, mainnet after grant phase.
# https://dashboard.helius.dev — generate a new key and ROTATE if ever leaked.
NEXT_PUBLIC_SOLANA_RPC_URL=

# ── Monitoring ──────────────────────────────────────────────────────────────

# Sentry — https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Required only in CI for source-map upload during build.
SENTRY_AUTH_TOKEN=
